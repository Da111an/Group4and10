<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Emergency Support | SafeHarbor</title>
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>
    <main class="landing">
        <div class="background-shapes" aria-hidden="true">
            <div class="shape shape-a"></div>
            <div class="shape shape-b"></div>
            <div class="shape shape-c"></div>
        </div>

        <section class="card sos-card">
            <h1>Immediate Help</h1>
            <p>If you are in immediate danger, call emergency services now.</p>

            <a class="help-now-button" href="tel:911">Call 911</a>
            <a class="primary-button" href="tel:988">Call or Text 988</a>
            <a class="text-link back-link" href="/">Back to Login</a>
        </section>
    </main>
</body>
</html>
