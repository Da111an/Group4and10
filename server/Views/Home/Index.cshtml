@{
    ViewData["Title"] = "SafeHarbor";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SafeHarbor Login</title>
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>
    <main class="landing">
        <div class="background-shapes" aria-hidden="true">
            <div class="shape shape-a"></div>
            <div class="shape shape-b"></div>
            <div class="shape shape-c"></div>
        </div>

        <section class="card auth-card">
            <div class="brand">
                <div class="logo-box">
                    <span class="logo-wave">~</span>
                </div>
                <h1>SafeHarbor</h1>
                <p>Sign in securely to continue your support journey.</p>
            </div>

            <section class="action-area">
                <div class="auth-switch">
                    <button id="show-login" class="switch-button active" type="button">Sign In</button>
                    <button id="show-create" class="switch-button" type="button">Create Account</button>
                </div>

                <section id="auth-status" class="status-message hidden" role="status" aria-live="polite"></section>

                <form id="login-form" class="auth-form">
                    <label for="login-email">Email</label>
                    <input id="login-email" name="email" type="email" maxlength="200" autocomplete="email" required />

                    <label for="login-password">Password</label>
                    <input id="login-password" name="password" type="password" autocomplete="current-password" required />

                    <button id="login-submit" class="primary-button" type="submit">Sign In</button>
                    <button id="go-create-inline" class="text-link" type="button">Need an account? Create one</button>
                </form>

                <form id="create-form" class="auth-form hidden">
                    <label for="create-full-name">Full Name</label>
                    <input id="create-full-name" name="fullName" type="text" maxlength="120" autocomplete="name" required />

                    <label for="create-email">Email</label>
                    <input id="create-email" name="email" type="email" maxlength="200" autocomplete="email" required />

                    <label for="create-password">Create Password</label>
                    <input id="create-password" name="password" type="password" autocomplete="new-password" required />

                    <button id="create-submit" class="primary-button" type="submit">Create Account</button>
                </form>
            </section>

            <a class="help-now-button" href="/sos">Get Help Now</a>

            <p class="footer-note">
                SafeHarbor is not a crisis service. If you are in danger, use emergency services immediately.
            </p>
        </section>
    </main>

    <script src="~/js/landing.js"></script>
</body>
</html>
